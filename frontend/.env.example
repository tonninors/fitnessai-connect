# ── Supabase (frontend - ANON key, es segura para el cliente) ──
# Obtener en: supabase.com > Project Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Backend URL (en prod: tu URL de Railway/Render) ────────────
# En desarrollo con proxy de Vite, no necesitas esta variable
VITE_API_URL=http://localhost:3000/api
